# ============================================
# SATŪS — Environment Variables
# ============================================
# Copy to .env.local:   cp .env.example .env.local
#
# Nothing here is required to boot the starter. Every integration is optional
# and self-disables when its env vars are absent. To add one:
#
#   • Scaffold env vars:   bun run setup:project
#   • Full list + types:   lib/env.ts          (Zod-validated source of truth)
#   • Per-integration:     lib/integrations/<name>/README.md
#                          (shopify · hubspot · mailchimp)
# ============================================

# Public site URL — SEO, canonical URLs, OG images, sitemap, robots.
# dev: http://localhost:3000   ·   prod: https://your-domain.com
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --------------------------------------------
# Payload CMS (required — admin panel + blog)
# --------------------------------------------
# Postgres connection string. Dev: Neon dev branch (https://console.neon.tech)
# or local Postgres. Prod: Neon via Vercel Marketplace.
DATABASE_URL="postgresql://user:password@host:5432/dbname"
# Long random string used to sign auth tokens: `openssl rand -hex 32`
PAYLOAD_SECRET=""
# Vercel Blob media storage (Vercel → Storage → Blob). Optional locally:
# without it the app boots but admin media uploads are disabled.
# BLOB_READ_WRITE_TOKEN=""

# --------------------------------------------
# Contact form email (optional — /kontakt delivery)
# --------------------------------------------
# SMTP for delivering /kontakt submissions to the team inbox via nodemailer.
# Runs on Google Workspace (smtp.gmail.com). Absent → the page renders but the
# submit fails gracefully (error state + server log), never throws.
# SMTP_PASS is a Google *app password* (16 chars, spaces stripped), which
# requires 2-Step Verification enabled on SMTP_USER's account:
#   Google Account → Security → 2-Step Verification → App passwords.
# SMTP_USER must equal (or be a send-as alias of) the authed account — Gmail
# rejects a mismatched `from`. CONTACT_INBOX is the destination (may equal USER).
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="halohalo@sociallama.pl"
# SMTP_PASS=""
# CONTACT_INBOX="halohalo@sociallama.pl"

# Storybook proxy (optional, Preview only). When set, /storybook on this domain
# proxies to your standalone Storybook deployment (build it with
# `bun run build-storybook`, output `storybook-static`). Leave UNSET in
# Production — the route is force-disabled there regardless. For local dev, run
# `bun storybook` and use http://localhost:6006 directly.
# NEXT_PUBLIC_STORYBOOK_URL="https://your-storybook.vercel.app"
